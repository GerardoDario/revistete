# OpenAI API Key (required for summarization)
OPENAI_API_KEY=sk-your-api-key-here

# Whisper model size: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=medium

# Language for transcription (es = Spanish)
WHISPER_LANGUAGE=es

# Audio chunk duration in seconds (for splitting long recordings)
CHUNK_DURATION_SECONDS=1800

# Output directories
TRANSCRIPTIONS_DIR=output/transcriptions
SUMMARIES_DIR=output/summaries

# Gmail IMAP (para confirmacion de pagos)
# IMPORTANTE: usa una 'Contrasena de aplicacion' de Google, NO tu contrasena normal
# Generala en: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=tu_correo@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Tolerancia de monto para matching de pagos (en pesos chilenos)
# Ej: 500 = acepta pagos con hasta $500 de diferencia por comisiones
PAYMENT_TOLERANCE=500

# Base de datos TITO
TITO_DB_PATH=tito.db
