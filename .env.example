# OpenAI API Key (required for summarization)
OPENAI_API_KEY=sk-your-api-key-here

# Whisper model size: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=medium

# Language for transcription (es = Spanish)
WHISPER_LANGUAGE=es

# Audio chunk duration in seconds (for splitting long recordings)
CHUNK_DURATION_SECONDS=1800

# Output directories
TRANSCRIPTIONS_DIR=output/transcriptions
SUMMARIES_DIR=output/summaries
